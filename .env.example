# Copy to .env for local docker-compose use. Never commit the real .env.

# Postgres credentials - used both to start the `db` service and to build
# DATABASE_URL for the `app` service in docker-compose.yml.
POSTGRES_USER=mindmap
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mindmap

# Port the app is exposed on from the host.
PORT=8080

# When running the backend directly (outside docker-compose), set the full
# connection string yourself, e.g.:
# DATABASE_URL=postgres://mindmap:changeme@localhost:5432/mindmap?sslmode=disable
